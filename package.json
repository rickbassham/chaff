{
  "name": "chaff",
  "version": "0.0.0",
  "description": "Keep env-var secrets out of LLM coding-harness transcripts via handle substitution and egress scrubbing",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "chaff": "dist/bin/chaff.js",
    "chaff-hook": "dist/bin/chaff-hook.js"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "secrets",
    "redaction",
    "llm",
    "claude-code",
    "security",
    "env"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"import('node:fs').then(fs => { fs.chmodSync('dist/bin/chaff.js', 0o755); fs.chmodSync('dist/bin/chaff-hook.js', 0o755); })\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.0"
  }
}
